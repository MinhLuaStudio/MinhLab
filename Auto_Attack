local NetSeed = ReplicatedStorage.Modules.Net:WaitForChild('seed')

task.spawn(function()
    while task.wait(0.05) do
        if not _G.AutoAttack then continue end

        local _Character = LocalPlayer.Character
        if not _Character then continue end

        local v13 = _Character:FindFirstChild('HumanoidRootPart')
        if not v13 then continue end

        local u17 = {}
        local enemiesFolder = Workspace:FindFirstChild("Enemies")
        local charactersFolder = Workspace:FindFirstChild("Characters")
        
        local function checkTargets(folder)
            if not folder then return end
            for _, target in ipairs(folder:GetChildren()) do
                if target == _Character then continue end
                
                local _HumanoidRootPart = target:FindFirstChild('HumanoidRootPart')
                local _Humanoid = target:FindFirstChild('Humanoid')

                if _HumanoidRootPart and _Humanoid and _Humanoid.Health > 0 then
                    if (_HumanoidRootPart.Position - v13.Position).Magnitude <= 60 then
                        table.insert(u17, {target, _HumanoidRootPart})
                    end
                end
            end
        end

        checkTargets(enemiesFolder)
        checkTargets(charactersFolder)

        local _Tool = _Character:FindFirstChildOfClass('Tool')

        if #u17 > 0 and _Tool and (_Tool:GetAttribute('WeaponType') == 'Melee' or _Tool:GetAttribute('WeaponType') == 'Sword') then
            local _Head = u17[1][1]:FindFirstChild('Head')
            
