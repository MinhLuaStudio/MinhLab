                end)
                
                local currentSeed = NetSeed:InvokeServer() * 2
                local xorValue = bit32.bxor(u5 + 909090, currentSeed)

                for i = 1, 5 do
                    task.spawn(function()
                        pcall(function()
                            NetModule:RemoteEvent('RegisterHit', true)
                            RegisterAttack:FireServer()
                            
                            local coStr = tostring(coroutine.running()):sub(11, 15)
                            RegisterHit:FireServer(_Head, u17, {}, userIdStr .. coStr)
                            
                            if u4 then
                                cloneref(u4):FireServer(obfuscatedHit, xorValue, _Head, u17)
                            end
                        end)
                    end)
