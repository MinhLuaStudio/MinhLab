        for _, btn in pairs(LeftPanel:GetChildren()) do
            if btn:IsA("TextButton") then
                CreateTween(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(35, 35, 40), TextColor3 = Color3.fromRGB(200, 200, 200)})
