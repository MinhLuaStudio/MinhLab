local function ApplyESP(model, isPlayer)
    if not model or not model:FindFirstChild("Head") or not model:FindFirstChild("Humanoid") or not model:FindFirstChild("HumanoidRootPart") then return end
    
    local hum = model.Humanoid
    local hrp = model.HumanoidRootPart
    local esp = model.Head:FindFirstChild("GreenDarkESP")
    
    if not esp then
        esp = Instance.new("BillboardGui")
        esp.Name = "GreenDarkESP"
        esp.Size = UDim2.new(0, 150, 0, 45)
        esp.StudsOffset = Vector3.new(0, 2.5, 0)
        esp.AlwaysOnTop = true
        esp.Parent = model.Head

        local txt = Instance.new("TextLabel")
        txt.Name = "Text"
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.Font = Enum.Font.GothamBold
        txt.TextSize = 12
        txt.TextStrokeTransparency = 0.2
        txt.Parent = esp
    end

    local txtLabel = esp.Text
    local isEnabled = isPlayer and espPlayer or (not isPlayer and espNpc)
    
    if isEnabled and hum.Health > 0 and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
        esp.Enabled = true
        local dist = math.floor((lp.Character.HumanoidRootPart.Position - hrp.Position).Magnitude)
        txtLabel.Text = string.format("%s | %dm\nHP: %d / %d", model.Name, dist, math.floor(hum.Health), math.floor(hum.MaxHealth))
        txtLabel.TextColor3 = isPlayer and ColorLight or Color3.new(1, 0.3, 0.3)
    else
        esp.Enabled = false
    end
end

local function GetNPCs()
    local npcs = {}
    if workspace:FindFirstChild("Enemies") then
        for _, v in pairs(workspace.Enemies:GetChildren()) do
            if v:IsA("Model") then table.insert(npcs, v) end
        end
    else
        for _, v in pairs(workspace:GetChildren()) do
            if v:IsA("Model") and v:FindFirstChild("Humanoid") then
                table.insert(npcs, v)
            end
        end
    end
    return npcs
end

task.spawn(function()
    while task.wait(0.2) do
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= lp and p.Character then
                ApplyESP(p.Character, true)
            end
        end

        if espNpc then
            for _, obj in ipairs(GetNPCs()) do
                if not Players:GetPlayerFromCharacter(obj) then
                    ApplyESP(obj, false)
                end
            end
        else
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Model") and obj:FindFirstChild("Head") then
                    local esp = obj.Head:FindFirstChild("GreenDarkESP")
                    if esp and not Players:GetPlayerFromCharacter(obj) then
                        esp.Enabled = false
                    end
                end
            end
        end
    end
end)
