local function CreateTween(object, info, properties)
    local tween = TweenService:Create(object, info, properties)
    tween:Play()
    return tween
end

MiniButton.MouseButton1Click:Connect(function()
    isMenuOpen = not isMenuOpen
    local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    
    if isMenuOpen then
        MainFrame.Visible = true
        CreateTween(MainFrame, tweenInfo, {Size = UDim2.new(0, 500, 0, 300)})
    else
        local closeTween = CreateTween(MainFrame, tweenInfo, {Size = UDim2.new(0, 0, 0, 0)})
        closeTween.Completed:Connect(function()
            if not isMenuOpen then MainFrame.Visible = false end
        end)
    end
end)

ToggleBg.MouseButton1Click:Connect(function()
    isToggleOn = not isToggleOn
    local tInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    
    _G.AutoAttack = isToggleOn
    _G.Auto_Attack = isToggleOn
    
    if isToggleOn then
        CreateTween(ToggleKnob, tInfo, {Position = UDim2.new(1, -22, 0.5, -10)})
        CreateTween(ToggleBg, tInfo, {BackgroundColor3 = GreenAccent})
        
        if not scriptExecuted then
            scriptExecuted = true
            task.spawn(function()
                pcall(function()
                    loadstring(game:HttpGet("https://raw.githubusercontent.com/MinhLuaStudio/MinhLab/refs/heads/main/Auto_Attack"))()
                end)
            end)
        end
    else
        CreateTween(ToggleKnob, tInfo, {Position = UDim2.new(0, 2, 0.5, -10)})
        CreateTween(ToggleBg, tInfo, {BackgroundColor3 = Color3.fromRGB(60, 60, 65)})
    end
end)

local function MakeDraggable(dragObject, targetObject)
    local dragging, dragInput, dragStart, startPos
    dragObject.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = targetObject.Position
        end
    end)
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if dragging and (input == dragInput or input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            targetObject.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    dragObject.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
    dragObject.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
end

MakeDraggable(MiniButton, MiniButton)
