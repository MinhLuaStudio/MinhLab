local lightningEnabled = true

local function createLightningStrike()
	local startPos = Vector3.new(math.random(-180, 180), 195, math.random(-180, 180))
	local endPos = startPos + Vector3.new(math.random(-30, 30), -190, math.random(-30, 30))
	
	local lightning = Instance.new("Part")
	lightning.Anchored = true
	lightning.CanCollide = false
	lightning.Transparency = 1
	lightning.Size = Vector3.new(1.1, (startPos - endPos).Magnitude, 1.1)
	lightning.CFrame = CFrame.lookAt(startPos, endPos) * CFrame.new(0, -lightning.Size.Y/2, 0)
	lightning.Parent = workspace
	
	local beam = Instance.new("Beam")
	beam.Color = ColorSequence.new(Color3.fromRGB(235, 235, 245))
	beam.LightEmission = 1
	beam.Transparency = NumberSequence.new(0.1, 0.8)
	beam.Width0 = 1.6
	beam.Width1 = 0.4
	beam.Texture = "rbxassetid://707177944"
	beam.TextureSpeed = 3
	beam.Segments = 14
	beam.Attachment0 = Instance.new("Attachment", lightning)
	beam.Attachment1 = Instance.new("Attachment", lightning)
	beam.Attachment1.Position = Vector3.new(0, -lightning.Size.Y, 0)
	beam.Parent = lightning
	
	Lighting.Brightness = 6.5
	ColorCorrection.TintColor = Color3.fromRGB(210, 210, 225)
	
	wait(0.08)
	Lighting.Brightness = 1.9
	ColorCorrection.TintColor = Color3.fromRGB(165, 165, 175)
	
	wait(0.2)
	lightning:Destroy()
end

spawn(function()
	while lightningEnabled do
		wait(math.random(8, 20))
		createLightningStrike()
		
		local randomSound = thunderInstances[math.random(1, #thunderInstances)]
		wait(math.random(0.7, 2.3))
		randomSound:Play()
		
		if math.random(1,3) == 1 then
			wait(0.4)
			createLightningStrike()
		end
	end
end)
